generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  role          String   @default("EMPLOYEE")
  department    String?
  designation   String?
  phone         String?
  location      String?
  avatar        String?
  loginUsername  String?  @unique
  loginPassword  String?
  isActive      Boolean  @default(true)
  joinDate      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdWorkflows    WorkflowInstance[]  @relation("WorkflowCreator")
  assignedSteps       StepInstance[]      @relation("StepAssignee")
  approvals          Approval[]          @relation("ApprovalUser")
  sentNotifications  Notification[]      @relation("NotificationSender")
  receivedNotifications Notification[]   @relation("NotificationReceiver")
  delegatedTo        Delegation[]        @relation("DelegatedTo")
  delegatedFrom      Delegation[]        @relation("DelegatedFrom")
  comments           Comment[]           @relation("CommentAuthor")
  tasks              Task[]              @relation("TaskOwner")
  assignedTaskSteps  TaskStep[]          @relation("StepAssigneeTask")
  managedProjects    Project[]           @relation("ProjectManager")
  deptHead           Department[]        @relation("DeptHead")
  mondayMeetings     MondayMeeting[]     @relation("MondayMeetingUser")
  leaves             Leave[]             @relation("UserLeaves")
  approvedLeaves     Leave[]             @relation("LeaveApprover")
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  headId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  head        User?    @relation("DeptHead", fields: [headId], references: [id])
  projects    Project[]
}

model WorkflowTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps       StepTemplate[]
  instances   WorkflowInstance[]
}

model StepTemplate {
  id              String   @id @default(cuid())
  templateId      String
  name            String
  stepType        String
  order           Int
  assigneeRole    String?
  approvalLevel   Int      @default(1)
  slaHours        Int?
  isParallel      Boolean  @default(false)
  conditionExpr   String?
  nextStepId      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  template        WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  instances       StepInstance[]
}

model WorkflowInstance {
  id              String   @id @default(cuid())
  templateId      String
  title           String
  description     String?
  status          String   @default("DRAFT")
  priority        String   @default("MEDIUM")
  currentStepOrder Int    @default(0)
  dueDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  template        WorkflowTemplate @relation(fields: [templateId], references: [id])
  creator         User            @relation("WorkflowCreator", fields: [creatorId], references: [id])
  creatorId       String
  steps           StepInstance[]
  approvals       Approval[]
  tasks           Task[]
  statusHistory   StatusHistory[]
  escalationLogs  EscalationLog[]
  comments        Comment[]
}

model StepInstance {
  id              String    @id @default(cuid())
  workflowId      String
  stepTemplateId  String
  name            String
  stepType        String
  order           Int
  status          String    @default("PENDING")
  assigneeId      String?
  startedAt       DateTime?
  completedAt     DateTime?
  slaDeadline     DateTime?
  isEscalated     Boolean   @default(false)
  remarks         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workflow        WorkflowInstance @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepTemplate    StepTemplate     @relation(fields: [stepTemplateId], references: [id])
  assignee        User?            @relation("StepAssignee", fields: [assigneeId], references: [id])
  approvals       Approval[]
}

model Approval {
  id              String   @id @default(cuid())
  stepInstanceId  String
  workflowId      String
  approverId      String
  action          String
  comments        String?
  level           Int      @default(1)
  isDelegated     Boolean  @default(false)
  originalApproverId String?
  createdAt       DateTime @default(now())

  stepInstance    StepInstance   @relation(fields: [stepInstanceId], references: [id], onDelete: Cascade)
  workflow        WorkflowInstance @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  approver        User           @relation("ApprovalUser", fields: [approverId], references: [id])
}

model Task {
  id              String    @id @default(cuid())
  workflowId      String?
  title           String
  description     String?
  status          String    @default("PENDING")
  priority        String    @default("MEDIUM")
  ownerId         String
  department      String?
  category        String?
  dueDate         DateTime?
  parentTaskId    String?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workflow        WorkflowInstance? @relation(fields: [workflowId], references: [id])
  owner           User              @relation("TaskOwner", fields: [ownerId], references: [id])
  parentTask      Task?             @relation("TaskChildren", fields: [parentTaskId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  subTasks        Task[]            @relation("TaskChildren")
  dependencies    TaskDependency[]  @relation("TaskDependsOn")
  dependents      TaskDependency[]  @relation("TaskRequiredBy")
  taskSteps       TaskStep[]
  projectId       String?
  project         Project?          @relation(fields: [projectId], references: [id])
  frequency       String?
  weekDays        String?
  monthDates      String?
  directorDependency String?

  // Revise tracking
  reviseReason    String?
  reviseNextDate  DateTime?
  revisedAt       DateTime?

  // Performance score
  score           Float?
}

model TaskStep {
  id                    String    @id @default(cuid())
  taskId                String
  title                 String
  status                String    @default("PENDING")
  order                 Int       @default(0)
  assigneeId            String?
  dueDate               DateTime?
  completedAt           DateTime?
  needsDirectorApproval Boolean   @default(false)
  directorName          String?
  directorNote          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  task        Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignee    User?          @relation("StepAssigneeTask", fields: [assigneeId], references: [id], onDelete: SetNull, onUpdate: Restrict)
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TaskDependency {
  id              String   @id @default(cuid())
  taskId          String
  dependsOnTaskId String
  dependencyType  String   @default("FINISH_TO_START")
  createdAt       DateTime @default(now())

  task            Task     @relation("TaskDependsOn", fields: [taskId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  dependsOnTask   Task     @relation("TaskRequiredBy", fields: [dependsOnTaskId], references: [id], onDelete: Restrict, onUpdate: Restrict)
}

model Notification {
  id          String    @id @default(cuid())
  type        String
  title       String
  message     String
  senderId    String?
  receiverId  String
  workflowId  String?
  isRead      Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  sender      User?            @relation("NotificationSender", fields: [senderId], references: [id])
  receiver    User             @relation("NotificationReceiver", fields: [receiverId], references: [id])
}

model EscalationLog {
  id              String   @id @default(cuid())
  workflowId      String
  fromStepOrder   Int
  toStepOrder     Int
  fromAssigneeId  String?
  toAssigneeId    String?
  reason          String
  slaBreached     Boolean  @default(false)
  createdAt       DateTime @default(now())

  workflow        WorkflowInstance @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model StatusHistory {
  id          String   @id @default(cuid())
  workflowId  String
  fromStatus  String
  toStatus    String
  changedBy   String?
  reason      String?
  createdAt   DateTime @default(now())

  workflow    WorkflowInstance @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model Delegation {
  id          String    @id @default(cuid())
  fromUserId  String
  toUserId    String
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean   @default(true)
  reason      String?
  createdAt   DateTime  @default(now())

  fromUser    User     @relation("DelegatedFrom", fields: [fromUserId], references: [id])
  toUser      User     @relation("DelegatedTo", fields: [toUserId], references: [id])
}

model Comment {
  id          String   @id @default(cuid())
  workflowId  String
  authorId    String
  content     String
  createdAt   DateTime @default(now())

  workflow    WorkflowInstance @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  author      User             @relation("CommentAuthor", fields: [authorId], references: [id])
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  department  String?
  managerId   String?
  status      String    @default("PENDING")
  priority    String    @default("MEDIUM")
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  manager     User?          @relation("ProjectManager", fields: [managerId], references: [id])
  dept        Department?    @relation(fields: [department], references: [name])
  tasks       Task[]
}

model Leave {
  id              String    @id @default(cuid())
  userId          String
  leaveType       String    @default("CASUAL")
  fromDate        DateTime
  toDate          DateTime
  reason          String
  status          String    @default("PENDING")
  // AL = Applied on time (1 day before), LA = Late Application (same day)
  applicationTag  String    @default("AL")
  // EA remark when approving/rejecting
  eaRemark        String?
  approvedById    String?
  approvedAt      DateTime?
  totalDays       Float     @default(1)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation("UserLeaves", fields: [userId], references: [id])
  approvedBy      User?     @relation("LeaveApprover", fields: [approvedById], references: [id])
}

model MondayMeeting {
  id              String   @id @default(cuid())
  userId          String
  weekStartDate   DateTime
  weekEndDate     DateTime
  weekNumber      Int
  year            Int
  // This Week Plan scores (0-100 percentage)
  planRedScore    Float    @default(0)
  planYellowScore Float    @default(0)
  planGreenScore  Float    @default(0)
  // Actual scores (0-100 percentage)
  actualRedScore  Float    @default(0)
  actualYellowScore Float  @default(0)
  actualGreenScore Float   @default(0)
  // Next Week Plan scores (0-100 percentage)
  nextRedScore    Float    @default(0)
  nextYellowScore Float    @default(0)
  nextGreenScore  Float    @default(0)
  // Performance Rating
  prScore         Float    @default(0)
  // Commitments for next week
  commitments     String?
  // Notes/remarks
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation("MondayMeetingUser", fields: [userId], references: [id])

  @@unique([userId, weekNumber, year])
}
